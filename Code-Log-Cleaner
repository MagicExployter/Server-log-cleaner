#!/bin/bash
# =============================================================================
# clean_old_logs.sh — ZimaOS log cleaner
# Deletes log files older than 14 days from standard Linux and ZimaOS paths.
# Safe to run manually or via cron.
# =============================================================================

set -euo pipefail

# --- Config ------------------------------------------------------------------
# You can change these to do whatever, and also add in whatever type of file you want to be deleted
MAX_AGE_DAYS=14
DRY_RUN=false   # Set to true to preview deletions without removing anything

LOG_DIRS=(
    "/var/log"                          # Standard Linux system logs
    "/root/.casaos/logs"                # ZimaOS / CasaOS core logs
    "/var/lib/casaos/logs"              # ZimaOS service logs
    "/DATA/AppData"                     # Docker app data (may contain logs)
)

# Extra find options: only match common log file extensions
LOG_PATTERNS=( "*.log" "*.log.*" "*.gz" "*.old" "*.1" "*.2" "*.3" "*.4" "*.5" )

# --- Helpers -----------------------------------------------------------------
BOLD="\033[1m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RED="\033[0;31m"
RESET="\033[0m"

log()  { echo -e "${GREEN}[INFO]${RESET}  $*"; }
warn() { echo -e "${YELLOW}[WARN]${RESET}  $*"; }
err()  { echo -e "${RED}[ERROR]${RESET} $*" >&2; }

# --- Parse args --------------------------------------------------------------
for arg in "$@"; do
    case "$arg" in
        --dry-run) DRY_RUN=true ;;
        --help)
            echo "Usage: $0 [--dry-run]"
            echo "  --dry-run   Preview files that would be deleted without removing them."
            exit 0
            ;;
        *) err "Unknown argument: $arg"; exit 1 ;;
    esac
done

# --- Main --------------------------------------------------------------------
echo -e "${BOLD}ZimaOS Log Cleaner${RESET} — files older than ${MAX_AGE_DAYS} days"
$DRY_RUN && warn "DRY RUN mode — no files will be deleted."
echo ""

TOTAL_FOUND=0
TOTAL_FREED=0

NAME_EXPR=()
for pat in "${LOG_PATTERNS[@]}"; do
    NAME_EXPR+=( -name "$pat" -o )
done
# Remove trailing -o
unset 'NAME_EXPR[-1]'

for DIR in "${LOG_DIRS[@]}"; do
    if [ ! -d "$DIR" ]; then
        warn "Skipping (not found): $DIR"
        continue
    fi

    log "Scanning: $DIR"

    
    while IFS= read -r -d '' FILE; do
        SIZE=$(du -b "$FILE" 2>/dev/null | cut -f1 || echo 0)
        TOTAL_FOUND=$(( TOTAL_FOUND + 1 ))
        TOTAL_FREED=$(( TOTAL_FREED + SIZE ))

        if $DRY_RUN; then
            echo "  [dry-run] would delete: $FILE ($(numfmt --to=iec "$SIZE"))"
        else
            rm -f "$FILE" && echo "  Deleted: $FILE ($(numfmt --to=iec "$SIZE"))"
        fi
    done < <(find "$DIR" -type f \( "${NAME_EXPR[@]}" \) -mtime +"$MAX_AGE_DAYS" -print0 2>/dev/null)
done

echo ""
if $DRY_RUN; then
    log "Dry run complete. Would remove ${TOTAL_FOUND} file(s) ($(numfmt --to=iec "$TOTAL_FREED") freed)."
else
    log "Done. Removed ${TOTAL_FOUND} file(s), freed ~$(numfmt --to=iec "$TOTAL_FREED")."
fi
